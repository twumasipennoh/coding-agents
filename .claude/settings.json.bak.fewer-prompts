{
  "permissions": {
    "allow": [
      "Read", "Write", "Edit", "Glob", "Grep",
      "Bash(git status*)", "Bash(git log*)", "Bash(git diff*)",
      "Bash(git branch*)", "Bash(git add *)", "Bash(ls *)", "Bash(cat *)",
      "Bash(npx vitest*)", "Bash(npx tsc*)", "Bash(npm run test*)",
      "Bash(npm run build*)", "Bash(npm -w *)", "Bash(npx playwright*)",
      "Bash(node *)", "Bash(mkdir *)",
      "Bash(git commit*)", "Bash(git push*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
