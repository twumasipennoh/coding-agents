{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(npx vitest*)",
      "Bash(npx tsc*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm -w *)",
      "Bash(npx playwright*)",
      "Bash(node *)",
      "Bash(mkdir *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "TodoWrite",
      "Bash(~/.claude/scripts/pipeline-step.sh:*)",
      "Bash(~/.claude/scripts/telegram-ping.sh:*)",
      "Bash(~/.claude/scripts/telegram-send-media.sh:*)",
      "Bash(~/.claude/scripts/longrun-tick.sh:*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git stash*)",
      "Bash(journalctl*)",
      "Bash(lsof*)",
      "Bash(systemctl*)",
      "Bash(mkdir*)",
      "Bash(chmod +x *)",
      "Bash(npx jest*)",
      "Bash(npx playwright test*)",
      "Bash(npx firebase-tools@latest*)",
      "Bash(node generate-mockup.js *)",
      "Bash(node setup-monitoring.js *)",
      "Bash(gh pr create*)",
      "mcp__claude_ai_Gmail__get_thread",
      "mcp__claude_ai_Gmail__search_threads",
      "mcp__claude_ai_Gmail__authenticate"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -20"
          }
        ]
      }
    ]
  }
}
